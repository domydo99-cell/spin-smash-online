{
  "name": "human-ai-racers-local",
  "version": "0.1.0",
  "private": true,
  "description": "Local multiplayer browser version of Wild Derby",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:web",
    "build:web": "node scripts/build-static.js",
    "cap:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:prepare": "npm run build && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "typescript": "^5.9.3"
  }
}
